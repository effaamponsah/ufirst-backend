# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="U-FirstSupport API"
PORT=8000
DEBUG=false

# Set to true to bypass JWT verification locally without Supabase.
# Enables the "Bearer dev:<user_id>:<role>" auth scheme for local requests.
DEV_MODE=false

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg DSN — docker-compose default shown below
DATABASE_URL=postgresql://ufirst:ufirst@localhost:5432/ufirst

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Supabase ─────────────────────────────────────────────────────────────────
# For local dev: either set SUPABASE_JWT_SECRET (HS256) or SUPABASE_JWKS_URL (RS256).
# Production: prefer SUPABASE_JWKS_URL so key rotation is automatic.
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Secret used to verify inbound Supabase webhook signatures
SUPABASE_WEBHOOK_SECRET=

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM field encryption (bank account numbers, etc.)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Open Banking ─────────────────────────────────────────────────────────────
OPENBANKING_PROVIDER=TRUELAYER        # TRUELAYER | YAPILY
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_WEBHOOK_SECRET=
# Sandbox URL — switch to https://api.truelayer.com for production
TRUELAYER_BASE_URL=https://api.truelayer-sandbox.com

# ── Celery ────────────────────────────────────────────────────────────────────
# Defaults to REDIS_URL if left blank
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
