# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="U-FirstSupport API"
PORT=8000
DEBUG=false

# Set to true to bypass JWT verification locally without Supabase.
# Enables the "Bearer dev:<user_id>:<role>" auth scheme for local requests.
DEV_MODE=false

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg DSN — docker-compose default shown below
DATABASE_URL=postgresql://ufirst:ufirst@localhost:5432/ufirst

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Supabase ─────────────────────────────────────────────────────────────────
# For local dev: either set SUPABASE_JWT_SECRET (HS256) or SUPABASE_JWKS_URL (RS256).
# Production: prefer SUPABASE_JWKS_URL so key rotation is automatic.
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Secret used to verify inbound KYC provider webhook signatures (HMAC-SHA256)
KYC_WEBHOOK_SECRET=

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM field encryption (bank account numbers, etc.)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Open Banking — TrueLayer ─────────────────────────────────────────────────
OPENBANKING_PROVIDER=TRUELAYER        # TRUELAYER (only provider in Phase 3)
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_WEBHOOK_SECRET=
# Sandbox endpoints — switch to api.truelayer.com / auth.truelayer.com for production
TRUELAYER_BASE_URL=https://api.truelayer-sandbox.com
TRUELAYER_AUTH_URL=https://auth.truelayer-sandbox.com
# Merchant account that receives open banking payments (create in TrueLayer console)
TRUELAYER_MERCHANT_ACCOUNT_ID=
# Redirect URI after bank authorisation (deep link for mobile, or server callback)
TRUELAYER_REDIRECT_URI=

# ── Card Processor — UP Nigeria (up-ng.com) ──────────────────────────────────
# Leave blank to run with the dev stub (DevCardProcessorClient).
# Set UP_NIGERIA_API_KEY once you have credentials from UP Nigeria.
# See app/modules/card/processor/up_nigeria.py for the full wiring guide.
UP_NIGERIA_API_KEY=
UP_NIGERIA_BASE_URL=https://api.up-ng.com
UP_NIGERIA_CARD_PROGRAM_ID=                   # assigned by UP Nigeria after onboarding
UP_NIGERIA_WEBHOOK_SECRET=                    # for verifying dispatch/status webhooks

# ── Card Payments — Stripe (Phase 3.8 fallback) ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_REDIRECT_URI=

# ── Application ───────────────────────────────────────────────────────────────
# Used to build webhook / redirect URIs when provider-specific URIs are not set
APP_BASE_URL=http://localhost:8000

# ── Celery ────────────────────────────────────────────────────────────────────
# Defaults to REDIS_URL if left blank
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
